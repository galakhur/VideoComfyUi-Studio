generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                 String           @id @default(cuid())
  title              String
  description        String?
  thumbnail          String?
  storyline          String?
  storylineSource    String           @default("MANUAL")
  storylineConfirmed Boolean          @default(false)
  currentStage       String           @default("STORYLINE")
  activeMuse         String?
  museControlLevel   String           @default("ASSISTANT")
  scenes             Scene[]
  characters         Character[]
  suggestions        MuseSuggestion[]
  chatMessages       MuseChatMessage[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Scene {
  id                   String           @id @default(cuid())
  projectId            String
  project              Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sceneNumber          Int
  title                String
  heading              String           @default("")
  description          String           @default("")
  dialogue             String?
  technicalNotes       String?
  notes                String?
  status               String           @default("SCRIPT")
  videoUrl             String?
  videoDurationSeconds Float?
  comfyImageWorkflowId String?
  comfyVideoWorkflowId String?
  keyframes            Keyframe[]
  sceneCharacters      SceneCharacter[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([projectId])
}

model Keyframe {
  id               String           @id @default(cuid())
  sceneId          String
  scene            Scene            @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  sequenceOrder    Int
  source           String           @default("VISUAL_MUSE")
  draftImageUrl    String?
  finalImageUrl    String?
  generationParams String?
  status           String           @default("DRAFT")
  referenceImages  ReferenceImage[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([sceneId])
}

model ReferenceImage {
  id         String   @id @default(cuid())
  keyframeId String
  keyframe   Keyframe @relation(fields: [keyframeId], references: [id], onDelete: Cascade)
  url        String
  width      Int
  height     Int
  alt        String?
  createdAt  DateTime @default(now())
}

model Character {
  id              String           @id @default(cuid())
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  shortBio        String?
  designNotes     String?
  primaryRole     String?
  sortOrder       Int              @default(0)
  promptPositive  String?
  promptNegative  String?
  tags            String           @default("[]")
  images          CharacterImage[]
  sceneCharacters SceneCharacter[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([projectId])
}

model CharacterImage {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  kind        String
  url         String
  width       Int
  height      Int
  source      String    @default("UPLOAD")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SceneCharacter {
  id          String    @id @default(cuid())
  sceneId     String
  scene       Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([sceneId, characterId])
}

model GenerationJob {
  id            String   @id @default(cuid())
  sceneId       String?
  providerId    String
  jobType       String
  status        String   @default("QUEUED")
  progress      Float    @default(0)
  message       String?
  outputPath    String?
  error         String?
  metadata      String?
  comfyPromptId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

model MuseSuggestion {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  muse      String
  message   String
  sceneId   String?
  actions   String   @default("[]")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([projectId])
}

model MuseChatMessage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String
  content   String
  muse      String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([projectId])
}

model ComfyWorkflow {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String
  workflowJson String
  inputMapping String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plugin {
  id           String              @id @default(cuid())
  name         String              @unique
  version      String
  description  String?
  author       String?
  isEnabled    Boolean             @default(true)
  configJson   String?
  endpoints    PluginEndpoint[]
  hooks        PluginHook[]
  uiExtensions PluginUiExtension[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model PluginEndpoint {
  id       String @id @default(cuid())
  pluginId String
  plugin   Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  method   String
  path     String
  handler  String
}

model PluginHook {
  id       String @id @default(cuid())
  pluginId String
  plugin   Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  event    String
  handler  String
  priority Int    @default(0)
}

model PluginUiExtension {
  id        String @id @default(cuid())
  pluginId  String
  plugin    Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  slot      String
  component String
}

model McpChatSession {
  id        String           @id @default(cuid())
  title     String           @default("New Session")
  metadata  String?
  messages  McpChatMessage[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model McpChatMessage {
  id         String         @id @default(cuid())
  sessionId  String
  session    McpChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String
  content    String
  toolName   String?
  toolInput  String?
  toolOutput String?
  createdAt  DateTime       @default(now())

  @@index([sessionId])
}

model AppSettings {
  id    String @id @default("singleton")
  key   String @unique
  value String
}
